# OpenAI API Configuration (Primary & Fallback)
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NANO=gpt-4o-mini
MODEL_MINI=gpt-4o-mini
MODEL_SONNET=gpt-4o

# DeepSeek API Configuration (For Classification)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini API Configuration (For Summarization & Digest)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# LLM Provider Selection (Options: deepseek, gemini, openai)
CLASSIFICATION_PROVIDER=deepseek
SUMMARIZATION_PROVIDER=gemini
DIGEST_PROVIDER=gemini

# Database Configuration (SQLite - local pipeline)
DB_PATH=./news.db

# CNC Report Database (MSSQL - Creditreform company matching)
DB_SERVER=your-server.svc.ch
DB_DATABASE=CAG_Analyse
DB_DRIVER=ODBC Driver 17 for SQL Server

# Pipeline Configuration
CONFIDENCE_THRESHOLD=0.70
MAX_ITEMS_PER_FEED=120
REQUEST_TIMEOUT_SEC=12
SCRAPING_TIMEOUT_SEC=30
MAX_CONCURRENT_REQUESTS=10

# Cost Limits
DAILY_COST_LIMIT=2.0
MONTHLY_COST_LIMIT=50.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs

# Output Configuration
OUTPUT_DIR=./out

# Feature Flags
ENABLE_BATCH_API=true
ENABLE_CACHING=true
ENABLE_PLAYWRIGHT_FALLBACK=true

# Email Configuration
# Email 1: VIP group (shared email, all in TO, they see each other)
EMAIL_RECIPIENTS=vip1@example.com,vip2@example.com
EMAIL_AUTO_SEND=false
EMAIL_SUBJECT_TEMPLATE=Creditreform News-Digest: {date} - {count} relevante Artikel
# Email 2+: Individual emails (each recipient gets own email, sees no one else)
EMAIL_BCC=user1@example.com,user2@example.com
# Sender address
EMAIL_SENDER=your-own@example.com
